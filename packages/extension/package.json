{
  "name": "@eve-studio/extension",
  "version": "0.1.0",
  "type": "module",
  "description": "Capture extension for eve-studio. Streams local eve session events to the Studio collector for live, read-only inspection.",
  "license": "MIT",
  "author": {
    "name": "Chris Jayden",
    "url": "https://x.com/itschrisjayden"
  },
  "keywords": [
    "eve",
    "ai-agents",
    "agent-observability",
    "agent-debugging",
    "extension",
    "telemetry"
  ],
  "homepage": "https://github.com/multiplehats/eve-studio#readme",
  "bugs": {
    "url": "https://github.com/multiplehats/eve-studio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiplehats/eve-studio.git",
    "directory": "packages/extension"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "eve": {
    "extension": "./ext"
  },
  "files": [
    "ext",
    "dist"
  ],
  "peerDependencies": {
    "eve": ">=0.22.3 <0.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eve": "0.22.4",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "eve build",
    "prepare": "eve build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.mjs"
    }
  }
}
