{
  "name": "eve-studio",
  "version": "0.1.0",
  "type": "module",
  "description": "Local observability workspace for eve agents. Inspect live sessions, messages, tool calls, steps, and usage in your browser.",
  "license": "MIT",
  "author": {
    "name": "Chris Jayden",
    "url": "https://x.com/itschrisjayden"
  },
  "keywords": [
    "eve",
    "ai-agents",
    "agent-observability",
    "agent-debugging",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/multiplehats/eve-studio#readme",
  "bugs": {
    "url": "https://github.com/multiplehats/eve-studio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiplehats/eve-studio.git",
    "directory": "packages/studio"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": { "node": ">=24" },
  "bin": { "eve-studio": "./dist/cli.js" },
  "files": ["dist"],
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "dependencies": {
    "commander": "^15.0.0",
    "eve": "0.22.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod 755 dist/cli.js",
    "prepack": "node scripts/prepack-check.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  }
}
